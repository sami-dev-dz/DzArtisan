# ==============================================
# DzArtisan Backend — Environment Variables
# ==============================================
# Copy this file to .env and fill in the values.

APP_NAME=DzArtisan
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Sanctum — Stateful Domains (frontend URL)
SANCTUM_STATEFUL_DOMAINS=localhost:3000
SESSION_DOMAIN=localhost

# ----- Database -----
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dzartisan
DB_USERNAME=root
DB_PASSWORD=

# ----- Redis -----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ----- Cloudinary -----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ----- Mail -----
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@dzartisan.com"
MAIL_FROM_NAME="DzArtisan"
